{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@ai-comic/auth": ["packages/auth/src/index.ts"],
      "@ai-comic/ai": ["packages/ai/src/index.ts"],
      "@ai-comic/assets": ["packages/assets/src/index.ts"],
      "@ai-comic/billing": ["packages/billing/src/index.ts"],
      "@ai-comic/characters": ["packages/characters/src/index.ts"],
      "@ai-comic/comic-studio": ["packages/comic-studio/src/index.ts"],
      "@ai-comic/config": ["packages/config/src/index.ts"],
      "@ai-comic/credits": ["packages/credits/src/index.ts"],
      "@ai-comic/db": ["packages/db/src/index.ts"],
      "@ai-comic/export": ["packages/export/src/index.ts"],
      "@ai-comic/projects": ["packages/projects/src/index.ts"],
      "@ai-comic/storage": ["packages/storage/src/index.ts"],
      "@ai-comic/ui/*": ["packages/ui/src/*"],
      "@ai-comic/utils": ["packages/utils/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "exclude": ["node_modules"]
}
