{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@ai-comic/config": ["packages/config/src/index.ts"],
      "@ai-comic/db": ["packages/db/src/index.ts"],
      "@ai-comic/projects": ["packages/projects/src/index.ts"],
      "@ai-comic/ui/*": ["packages/ui/src/*"],
      "@ai-comic/utils": ["packages/utils/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "exclude": ["node_modules"]
}
